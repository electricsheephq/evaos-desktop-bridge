<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.electricsheep.evaos-desktop-bridge</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/evaos-desktop-bridge</string>
    <string>customer-mac</string>
    <string>status</string>
    <string>--json</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>300</integer>
  <key>StandardOutPath</key>
  <string>/Library/Logs/evaos-desktop-bridge/stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/Library/Logs/evaos-desktop-bridge/stderr.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>EVAOS_DESKTOP_BRIDGE_MODE</key>
    <string>customer-mac-connector</string>
  </dict>
</dict>
</plist>
